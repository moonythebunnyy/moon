    game:GetService("ReplicatedStorage").Remotes.DoMagic:FireServer(
        ability.Name,
        ability.Power,
        {Mouse = mouseHit, Camera = CFrame.new()}
    )
end

local function startInstantSpam()
    local player = game.Players.LocalPlayer
    local mouse = player:GetMouse()
    
    abilityLoops.instant = RunService.Heartbeat:Connect(function()
        if not noCDEnabled then return end
        local mouseHit = mouse.Hit.Position
        
        -- Fire all abilities simultaneously
        for _, ability in pairs(abilities) do
            fireAbility(ability, mouseHit)
        end
    end)
end

