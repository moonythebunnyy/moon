local function executeDash()
    require(game.ReplicatedStorage.Magic.Ability.Dash).Client(Player, {}, true)
end

local function isInDashZone(touchPosition)
    local screenSize = workspace.CurrentCamera.ViewportSize
    local zoneStart = Vector2.new(screenSize.X * 0.75, screenSize.Y * 0.5)
    local zoneEnd = Vector2.new(screenSize.X, screenSize.Y)
    return touchPosition.X >= zoneStart.X and touchPosition.Y >= zoneStart.Y
       and touchPosition.X <= zoneEnd.X and touchPosition.Y <= zoneEnd.Y
end

local function setupConnections()
    pcConnection = UIS.InputBegan:Connect(function(input, gameProcessed)
        if not gameProcessed and input.KeyCode == Enum.KeyCode.Q then
            executeDash()
        end
    end)

    mobileConnection = UIS.TouchStarted:Connect(function(touch, gameProcessed)
        if not gameProcessed and isInDashZone(touch.Position) then
            executeDash()
        end
    end)
end

local function cleanupConnections()
    if pcConnection then
        pcConnection:Disconnect()
        pcConnection = nil
    end
    if mobileConnection then
        mobileConnection:Disconnect()
        mobileConnection = nil
    end
end

