local antiRagdollEnabled = false
local characterConnections = {}
local characterAddedConnection = nil

local function cleanupConnections()
    for _, connections in pairs(characterConnections) do
        for _, conn in ipairs(connections) do
            conn:Disconnect()
        end
    end
    characterConnections = {}
    
    if characterAddedConnection then
        characterAddedConnection:Disconnect()
        characterAddedConnection = nil
    end
end

local function setupCharacter(character)
    if not antiRagdollEnabled then return end
    
    local humanoid = character:WaitForChild("Humanoid")
    humanoid.Sit = false
    
    characterConnections[character] = {}
    local connections = characterConnections[character]
    
    local function handleBadState(newState)
        if newState == Enum.HumanoidStateType.Ragdoll or 
           newState == Enum.HumanoidStateType.FallingDown or 
           newState == Enum.HumanoidStateType.PlatformStanding or
           newState == Enum.HumanoidStateType.Seated then
            humanoid:ChangeState(Enum.HumanoidStateType.GettingUp)
            humanoid.Sit = false
            return true
        end
        return false
    end
    
    table.insert(connections, humanoid.StateChanged:Connect(function(_, newState)
        handleBadState(newState)
    end))
    
    for _, seat in pairs(workspace:GetDescendants()) do
        if seat:IsA("Seat") then
            table.insert(connections, seat:GetPropertyChangedSignal("Occupant"):Connect(function()
                if seat.Occupant == humanoid then
                    humanoid.Sit = false
                    humanoid:ChangeState(Enum.HumanoidStateType.GettingUp)
                end
            end))
        end
    end
    
    table.insert(connections, humanoid.Died:Connect(function()
        if characterConnections[character] then
            for _, conn in ipairs(characterConnections[character]) do
                conn:Disconnect()
            end
            characterConnections[character] = nil
        end
    end))
end

