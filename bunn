local antiVoidEnabled = false
local heartbeatConnection = nil
local stateChangedConnection = nil
local voidEffect = nil
local player = Players.LocalPlayer
local character = nil
local humanoid = nil
local voidLevel = -100
local lastSafePosition = Vector3.new(-114, 7, 124)
local positionHistory = {}
local maxHistoryTime = 1
local minGroundDistance = 5

local function isPositionOnGround(position)
    local rayOrigin = position + Vector3.new(0, 0.5, 0)
    local rayDirection = Vector3.new(0, -minGroundDistance, 0)
    local raycastParams = RaycastParams.new()
    raycastParams.FilterDescendantsInstances = {character}
    raycastParams.FilterType = Enum.RaycastFilterType.Blacklist
    local raycastResult = Workspace:Raycast(rayOrigin, rayDirection, raycastParams)
    if raycastResult and raycastResult.Instance then
        return true, raycastResult.Position + Vector3.new(0, 0.5, 0)
    end
    return false
end

local function updateSafePosition()
    if not character or not character:FindFirstChild("HumanoidRootPart") then return end
    local rootPart = character.HumanoidRootPart
    local currentTime = os.clock()
    if rootPart.Position.Y > voidLevel and humanoid:GetState() ~= Enum.HumanoidStateType.Freefall then
        local onGround, groundPosition = isPositionOnGround(rootPart.Position)
        if onGround then
            table.insert(positionHistory, {
                position = groundPosition,
                time = currentTime
            })
            while #positionHistory > 0 and (currentTime - positionHistory[1].time) > maxHistoryTime do
                table.remove(positionHistory, 1)
            end
            if #positionHistory > 0 then
                lastSafePosition = positionHistory[1].position
            end
        end
    end
end

local function checkVoid()
    if not character or not character:FindFirstChild("HumanoidRootPart") then return end
    local rootPart = character.HumanoidRootPart
    if rootPart.Position.Y < voidLevel then
        local safePos = lastSafePosition
        for i = #positionHistory, 1, -1 do
            if positionHistory[i].position.Y > voidLevel then
                safePos = positionHistory[i].position
                break
            end
        end
        local onGround, adjustedPos = isPositionOnGround(safePos)
        if not onGround then
            local raycastParams = RaycastParams.new()
            raycastParams.FilterDescendantsInstances = {character}
            raycastParams.FilterType = Enum.RaycastFilterType.Blacklist
            local rayOrigin = safePos + Vector3.new(0, 50, 0)
            local rayDirection = Vector3.new(0, -100, 0)
            local raycastResult = Workspace:Raycast(rayOrigin, rayDirection, raycastParams)
            if raycastResult and raycastResult.Instance then
                safePos = raycastResult.Position + Vector3.new(0, 0.5, 0)
            end
        end
        character:SetPrimaryPartCFrame(CFrame.new(safePos))
        if rootPart:FindFirstChild("BodyVelocity") then
            rootPart.BodyVelocity.Velocity = Vector3.new(0, 0, 0)
        end
        positionHistory = {}
    end
end

